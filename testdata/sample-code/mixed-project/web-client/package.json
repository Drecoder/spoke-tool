{
  "name": "mixed-project-web-client",
  "version": "1.0.0",
  "description": "Modern web client for the mixed-language project with React, TypeScript, and real-time features",
  "keywords": [
    "react",
    "typescript",
    "web",
    "frontend",
    "dashboard",
    "real-time",
    "websocket",
    "api-client"
  ],
  "homepage": "https://github.com/yourusername/mixed-project#readme",
  "bugs": {
    "url": "https://github.com/yourusername/mixed-project/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yourusername/mixed-project.git"
  },
  "license": "MIT",
  "author": {
    "name": "Your Company",
    "email": "dev@yourcompany.com",
    "url": "https://yourcompany.com"
  },
  "contributors": [
    {
      "name": "John Doe",
      "email": "john@example.com"
    },
    {
      "name": "Jane Smith",
      "email": "jane@example.com"
    }
  ],
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "style": "dist/styles.css",
  "files": [
    "dist",
    "src",
    "public",
    "README.md",
    "LICENSE"
  ],
  "directories": {
    "src": "src",
    "test": "tests",
    "public": "public",
    "docs": "docs"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0",
    "yarn": ">=1.22.0",
    "pnpm": ">=8.0.0"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "dev:host": "vite --host",
    "dev:https": "vite --https",
    "build": "tsc && vite build",
    "build:analyze": "vite build --mode analyze",
    "build:prod": "vite build --mode production",
    "build:staging": "vite build --mode staging",
    "preview": "vite preview",
    "preview:host": "vite preview --host",
    "serve": "serve dist",
    "clean": "rimraf dist coverage .nyc_output node_modules/.cache",
    "clean:all": "rimraf dist coverage .nyc_output node_modules",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint src --fix --ext .js,.jsx,.ts,.tsx",
    "lint:cache": "eslint src --cache --ext .js,.jsx,.ts,.tsx",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "test:e2e": "cypress run",
    "test:e2e:open": "cypress open",
    "test:component": "cypress run-ct",
    "test:component:open": "cypress open-ct",
    "test:integration": "jest --testMatch='**/integration/**/*.test.{js,ts}'",
    "test:unit": "jest --testMatch='**/unit/**/*.test.{js,ts}'",
    "test:update": "jest --updateSnapshot",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "storybook:deploy": "storybook-to-ghpages",
    "chromatic": "npx chromatic --project-token=your-token",
    "docs": "typedoc --out docs src",
    "docs:serve": "serve docs",
    "analyze": "source-map-explorer 'dist/assets/*.js'",
    "bundle:report": "vite-bundle-visualizer",
    "size": "bundlesize",
    "depcheck": "depcheck",
    "outdated": "npm outdated",
    "update": "npm update",
    "upgrade": "npx npm-check-updates -u",
    "postinstall": "husky install",
    "precommit": "lint-staged",
    "prepare": "husky install",
    "prepush": "npm run lint && npm run test",
    "version": "conventional-changelog -p angular -i CHANGELOG.md -s && git add CHANGELOG.md",
    "postversion": "git push && git push --tags",
    "release": "standard-version",
    "release:major": "standard-version --release-as major",
    "release:minor": "standard-version --release-as minor",
    "release:patch": "standard-version --release-as patch",
    "deploy": "npm run build && gh-pages -d dist",
    "deploy:prod": "npm run build:prod && aws s3 sync dist/ s3://your-bucket",
    "deploy:staging": "npm run build:staging && netlify deploy --dir=dist",
    "docker:build": "docker build -t mixed-project-web-client .",
    "docker:run": "docker run -p 3000:3000 mixed-project-web-client",
    "docker:compose": "docker-compose up -d"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.0.1",
    "@tanstack/react-query": "^5.12.2",
    "@tanstack/react-table": "^8.10.7",
    "axios": "^1.6.2",
    "classnames": "^2.3.2",
    "date-fns": "^3.0.6",
    "framer-motion": "^10.16.16",
    "history": "^5.3.0",
    "i18next": "^23.7.11",
    "i18next-browser-languagedetector": "^7.2.0",
    "i18next-http-backend": "^2.4.2",
    "immer": "^10.0.3",
    "lodash-es": "^4.17.21",
    "prop-types": "^15.8.1",
    "qs": "^6.11.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-error-boundary": "^4.0.11",
    "react-helmet-async": "^2.0.4",
    "react-hook-form": "^7.48.2",
    "react-hot-toast": "^2.4.1",
    "react-i18next": "^14.0.1",
    "react-redux": "^9.0.4",
    "react-router-dom": "^6.21.0",
    "react-select": "^5.8.0",
    "react-table": "^7.8.0",
    "react-virtual": "^2.10.4",
    "socket.io-client": "^4.5.4",
    "swr": "^2.2.4",
    "uuid": "^9.0.1",
    "validator": "^13.11.0",
    "yup": "^1.3.3",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@babel/core": "^7.23.5",
    "@babel/preset-env": "^7.23.5",
    "@babel/preset-react": "^7.23.3",
    "@babel/preset-typescript": "^7.23.3",
    "@commitlint/cli": "^18.4.3",
    "@commitlint/config-conventional": "^18.4.3",
    "@cypress/react": "^8.0.0",
    "@cypress/vite-dev-server": "^5.0.6",
    "@faker-js/faker": "^8.3.1",
    "@redux-devtools/extension": "^3.3.0",
    "@storybook/addon-actions": "^7.6.3",
    "@storybook/addon-essentials": "^7.6.3",
    "@storybook/addon-interactions": "^7.6.3",
    "@storybook/addon-links": "^7.6.3",
    "@storybook/addon-styling": "^1.3.7",
    "@storybook/blocks": "^7.6.3",
    "@storybook/react": "^7.6.3",
    "@storybook/react-vite": "^7.6.3",
    "@storybook/test": "^7.6.3",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/jest": "^29.5.11",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.10.4",
    "@types/prop-types": "^15.7.11",
    "@types/qs": "^6.9.10",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.17",
    "@types/react-helmet": "^6.1.11",
    "@types/react-redux": "^7.1.33",
    "@types/react-router-dom": "^5.3.3",
    "@types/react-table": "^7.7.19",
    "@types/uuid": "^9.0.7",
    "@types/validator": "^13.11.7",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "babel-jest": "^29.7.0",
    "bundlesize": "^0.18.1",
    "chromatic": "^10.2.2",
    "commitizen": "^4.3.0",
    "conventional-changelog-cli": "^4.1.0",
    "cross-env": "^7.0.3",
    "cssnano": "^6.0.1",
    "cypress": "^13.6.1",
    "depcheck": "^1.4.7",
    "dotenv": "^16.3.1",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-cypress": "^2.15.1",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-jest": "^27.6.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-prettier": "^5.0.1",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-storybook": "^0.6.15",
    "eslint-plugin-testing-library": "^6.2.0",
    "gh-pages": "^6.1.1",
    "happy-dom": "^12.10.3",
    "husky": "^8.0.3",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-transform-stub": "^2.0.0",
    "lint-staged": "^15.2.0",
    "markdownlint-cli": "^0.38.0",
    "msw": "^2.0.11",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.32",
    "postcss-flexbugs-fixes": "^5.0.2",
    "postcss-preset-env": "^9.3.0",
    "prettier": "^3.1.1",
    "prettier-plugin-organize-imports": "^3.2.4",
    "prettier-plugin-packagejson": "^2.4.7",
    "rimraf": "^5.0.5",
    "sass": "^1.69.5",
    "serve": "^14.2.1",
    "source-map-explorer": "^2.5.3",
    "standard-version": "^9.5.0",
    "storybook": "^7.6.3",
    "stylelint": "^16.0.2",
    "stylelint-config-standard": "^35.0.0",
    "tailwindcss": "^3.3.6",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typedoc": "^0.25.4",
    "typescript": "^5.3.3",
    "vite": "^5.0.7",
    "vite-bundle-visualizer": "^1.0.0",
    "vite-plugin-checker": "^0.6.2",
    "vite-plugin-eslint": "^1.8.1",
    "vite-plugin-pwa": "^0.17.4",
    "vite-plugin-svgr": "^4.2.0",
    "vite-tsconfig-paths": "^4.2.2",
    "vitest": "^1.0.4",
    "web-vitals": "^3.5.0",
    "workbox-window": "^7.0.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.9.1",
    "fsevents": "^2.3.3"
  },
  "overrides": {
    "react": "$react",
    "react-dom": "$react-dom"
  },
  "resolutions": {
    "@types/react": "18.2.45",
    "@types/react-dom": "18.2.17"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "jsdom",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ],
    "moduleNameMapper": {
      "\\.(css|less|scss|sass)$": "identity-obj-proxy",
      "\\.(jpg|jpeg|png|gif|eot|otf|webp|svg|ttf|woff|woff2|mp4|webm|wav|mp3|m4a|aac|oga)$": "<rootDir>/__mocks__/fileMock.js"
    },
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    },
    "collectCoverageFrom": [
      "src/**/*.{js,jsx,ts,tsx}",
      "!src/**/*.d.ts",
      "!src/index.tsx",
      "!src/serviceWorker.ts"
    ]
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,scss,md}": [
      "prettier --write"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "sideEffects": false,
  "module": "dist/index.esm.js",
  "unpkg": "dist/index.umd.js",
  "jsdelivr": "dist/index.umd.js",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}