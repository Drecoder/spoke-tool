{
  "name": "nodejs-complex-api",
  "version": "1.0.0",
  "description": "A complex Node.js API example with authentication, database, caching, and real-time features",
  "keywords": [
    "nodejs",
    "express",
    "api",
    "rest",
    "graphql",
    "websocket",
    "mongodb",
    "redis",
    "jwt",
    "microservices"
  ],
  "homepage": "https://github.com/yourusername/nodejs-complex-api#readme",
  "bugs": {
    "url": "https://github.com/yourusername/nodejs-complex-api/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yourusername/nodejs-complex-api.git"
  },
  "license": "MIT",
  "author": {
    "name": "Your Name",
    "email": "your.email@example.com",
    "url": "https://yourwebsite.com"
  },
  "contributors": [
    {
      "name": "Contributor Name",
      "email": "contributor@example.com"
    }
  ],
  "main": "src/server.js",
  "types": "src/types/index.d.ts",
  "files": [
    "src",
    "config",
    "scripts",
    "README.md",
    "LICENSE"
  ],
  "directories": {
    "src": "src",
    "test": "tests",
    "docs": "docs",
    "config": "config",
    "scripts": "scripts"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0",
    "yarn": ">=1.22.0",
    "pnpm": ">=8.0.0"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "private": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "node src/server.js",
    "start:prod": "NODE_ENV=production node src/server.js",
    "start:dev": "nodemon src/server.js",
    "start:debug": "nodemon --inspect src/server.js",
    "start:cluster": "node src/cluster.js",
    "dev": "cross-env NODE_ENV=development nodemon src/server.js",
    "dev:debug": "cross-env NODE_ENV=development nodemon --inspect src/server.js",
    "prod": "cross-env NODE_ENV=production node src/server.js",
    "staging": "cross-env NODE_ENV=staging node src/server.js",
    
    "build": "npm run clean && npm run compile",
    "build:prod": "npm run clean && npm run compile:prod",
    "clean": "rimraf dist coverage .nyc_output node_modules/.cache",
    "clean:all": "rimraf dist coverage .nyc_output node_modules",
    "compile": "babel src --out-dir dist --copy-files",
    "compile:prod": "babel src --out-dir dist --copy-files --minified",
    "watch": "babel src --out-dir dist --watch --copy-files",
    
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "test:unit": "jest --testMatch='**/unit/**/*.test.js'",
    "test:integration": "jest --testMatch='**/integration/**/*.test.js'",
    "test:e2e": "jest --testMatch='**/e2e/**/*.test.js'",
    "test:api": "newman run tests/postman/collection.json -e tests/postman/environment.json",
    "test:load": "k6 run tests/load/spike-test.js",
    "test:security": "npm audit && snyk test",
    
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint src --fix --ext .js,.jsx,.ts,.tsx",
    "lint:cache": "eslint src --cache --ext .js,.jsx,.ts,.tsx",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "typecheck": "tsc --noEmit",
    
    "db:migrate": "node scripts/migrate.js",
    "db:migrate:create": "node scripts/create-migration.js",
    "db:seed": "node scripts/seed.js",
    "db:seed:prod": "NODE_ENV=production node scripts/seed.js",
    "db:backup": "node scripts/backup.js",
    "db:restore": "node scripts/restore.js",
    "db:drop": "node scripts/drop-db.js",
    
    "cache:clear": "node scripts/clear-cache.js",
    "cache:stats": "node scripts/cache-stats.js",
    
    "queue:worker": "node src/workers/queue-worker.js",
    "queue:failed": "node scripts/retry-failed-jobs.js",
    "queue:clear": "node scripts/clear-queue.js",
    
    "cron:run": "node src/cron/index.js",
    "cron:sync": "node src/cron/sync-data.js",
    "cron:cleanup": "node src/cron/cleanup.js",
    
    "docs:generate": "jsdoc -c jsdoc.json",
    "docs:serve": "serve docs",
    "docs:deploy": "gh-pages -d docs",
    "swagger": "node scripts/generate-swagger.js",
    "swagger:serve": "swagger-ui-dist",
    
    "metrics": "node scripts/metrics.js",
    "health": "node scripts/health-check.js",
    
    "docker:build": "docker build -t nodejs-complex-api .",
    "docker:run": "docker run -p 3000:3000 nodejs-complex-api",
    "docker:compose": "docker-compose up -d",
    "docker:compose:down": "docker-compose down",
    "docker:push": "docker push yourusername/nodejs-complex-api",
    
    "deploy:staging": "node scripts/deploy-staging.js",
    "deploy:prod": "node scripts/deploy-prod.js",
    "deploy:rollback": "node scripts/rollback.js",
    
    "logs": "tail -f logs/app.log",
    "logs:error": "tail -f logs/error.log",
    "logs:access": "tail -f logs/access.log",
    
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:delete": "pm2 delete ecosystem.config.js",
    "pm2:logs": "pm2 logs",
    "pm2:monit": "pm2 monit",
    "pm2:status": "pm2 status",
    
    "prepare": "husky install",
    "pre-commit": "lint-staged",
    "pre-push": "npm run lint && npm run test",
    "commit": "cz",
    "release": "standard-version",
    "release:major": "standard-version --release-as major",
    "release:minor": "standard-version --release-as minor",
    "release:patch": "standard-version --release-as patch",
    "postrelease": "git push --follow-tags origin main && npm publish",
    
    "audit": "npm audit",
    "audit:fix": "npm audit fix",
    "outdated": "npm outdated",
    "update": "npm update",
    "upgrade": "npx npm-check-updates -u",
    
    "validate": "npm run lint && npm run test && npm run audit",
    "ci": "npm run lint && npm run test:ci && npm run build",
    "prepublishOnly": "npm run validate && npm run build",
    "postpublish": "git push && git push --tags"
  },
  "dependencies": {
    "@graphql-tools/schema": "^10.0.0",
    "@hapi/joi": "^17.1.1",
    "@opentelemetry/api": "^1.6.0",
    "@opentelemetry/auto-instrumentations-node": "^0.39.4",
    "@opentelemetry/exporter-jaeger": "^1.17.1",
    "@opentelemetry/sdk-node": "^0.46.0",
    "@prisma/client": "^5.7.0",
    "apollo-server-express": "^3.13.0",
    "argon2": "^0.31.2",
    "aws-sdk": "^2.1503.0",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "bull": "^4.11.5",
    "bull-board": "^5.1.0",
    "celebrate": "^15.0.3",
    "compression": "^1.7.4",
    "connect-redis": "^7.1.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "cron": "^3.1.6",
    "csv-writer": "^1.6.0",
    "dotenv": "^16.3.1",
    "dotenv-expand": "^11.0.3",
    "elastic-apm-node": "^4.5.0",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-brute": "^1.0.1",
    "express-brute-redis": "^0.0.2",
    "express-fileupload": "^1.4.3",
    "express-graphql": "^0.12.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.17.3",
    "express-validator": "^7.0.1",
    "graphql": "^16.8.1",
    "graphql-depth-limit": "^1.1.0",
    "graphql-query-complexity": "^0.12.0",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "http-status-codes": "^2.3.0",
    "ioredis": "^5.3.2",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.1.0",
    "kafkajs": "^2.2.4",
    "lodash": "^4.17.21",
    "lusca": "^1.7.0",
    "method-override": "^3.0.0",
    "moment": "^2.29.4",
    "moment-timezone": "^0.5.43",
    "mongoose": "^8.0.3",
    "mongoose-autopopulate": "^1.0.1",
    "mongoose-lean-virtuals": "^0.9.1",
    "mongoose-paginate-v2": "^1.7.4",
    "mongoose-unique-validator": "^4.0.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "multer-s3": "^3.0.1",
    "nanoid": "^5.0.4",
    "newrelic": "^11.8.0",
    "node-cache": "^5.1.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.7",
    "oauth2-server": "^3.1.1",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pdfkit": "^0.14.0",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "prom-client": "^15.0.0",
    "pug": "^3.0.2",
    "qrcode": "^1.5.3",
    "qs": "^6.11.2",
    "rate-limit-redis": "^4.0.0",
    "redis": "^4.6.11",
    "reflect-metadata": "^0.2.1",
    "request-ip": "^3.3.0",
    "sequelize": "^6.35.1",
    "sharp": "^0.33.0",
    "socket.io": "^4.5.4",
    "socket.io-client": "^4.5.4",
    "speakeasy": "^2.0.0",
    "stripe": "^14.8.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "typeorm": "^0.3.17",
    "uuid": "^9.0.1",
    "validator": "^13.11.0",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "xss": "^1.0.14",
    "xss-clean": "^0.1.4",
    "yamljs": "^0.3.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@babel/cli": "^7.23.4",
    "@babel/core": "^7.23.5",
    "@babel/eslint-parser": "^7.23.3",
    "@babel/node": "^7.22.19",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-decorators": "^7.23.5",
    "@babel/plugin-proposal-export-default-from": "^7.23.3",
    "@babel/plugin-proposal-nullish-coalescing-operator": "^7.18.6",
    "@babel/plugin-proposal-optional-chaining": "^7.21.0",
    "@babel/plugin-transform-runtime": "^7.23.4",
    "@babel/preset-env": "^7.23.5",
    "@babel/preset-typescript": "^7.23.3",
    "@babel/register": "^7.22.15",
    "@babel/runtime": "^7.23.5",
    "@commitlint/cli": "^18.4.3",
    "@commitlint/config-conventional": "^18.4.3",
    "@faker-js/faker": "^8.3.1",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.4",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "artillery": "^2.0.4",
    "autocannon": "^7.14.0",
    "babel-jest": "^29.7.0",
    "benchmark": "^2.1.4",
    "chai": "^4.3.10",
    "chance": "^1.1.11",
    "concurrently": "^8.2.2",
    "coveralls": "^3.1.1",
    "cross-env": "^7.0.3",
    "cypress": "^13.6.1",
    "cz-conventional-changelog": "^3.3.0",
    "depcheck": "^1.4.7",
    "dotenv-cli": "^7.3.0",
    "eslint": "^8.55.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-jest": "^27.6.0",
    "eslint-plugin-jsdoc": "^46.9.1",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.0.1",
    "eslint-plugin-promise": "^6.1.1",
    "eslint-plugin-security": "^2.1.0",
    "eslint-plugin-unicorn": "^49.0.0",
    "faker": "^5.5.3",
    "git-commit-msg-linter": "^5.0.4",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "jest-html-reporter": "^3.10.2",
    "jest-junit": "^16.0.0",
    "jest-sonar-reporter": "^2.0.0",
    "jsdoc": "^4.0.2",
    "k6": "^0.0.0",
    "lint-staged": "^15.2.0",
    "markdownlint-cli": "^0.38.0",
    "mocha": "^10.2.0",
    "mockdate": "^3.0.5",
    "msw": "^2.0.11",
    "nock": "^13.4.0",
    "nodemon": "^3.0.2",
    "nyc": "^15.1.0",
    "pm2": "^5.3.0",
    "prettier": "^3.1.1",
    "pretty-quick": "^4.0.0",
    "rimraf": "^5.0.5",
    "sinon": "^17.0.1",
    "snyk": "^1.1265.0",
    "standard-version": "^9.5.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typedoc": "^0.25.4",
    "typescript": "^5.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-node-externals": "^3.0.0"
  },
  "peerDependencies": {
    "express": ">=4.0.0"
  },
  "optionalDependencies": {
    "bufferutil": "^4.0.8",
    "utf-8-validate": "^6.0.3"
  },
  "overrides": {
    "express": "$express",
    "mongoose": "$mongoose"
  },
  "resolutions": {
    "**/lodash": "4.17.21",
    "**/minimist": "1.2.8"
  },
  "browserslist": [
    "node >= 18"
  ],
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/tests/"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/**/*.test.js",
      "!src/server.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    },
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.js"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "nodemonConfig": {
    "watch": [
      "src"
    ],
    "ext": "js,json",
    "ignore": [
      "src/**/*.test.js"
    ],
    "delay": "1",
    "env": {
      "NODE_ENV": "development"
    }
  },
  "babel": {
    "presets": [
      "@babel/preset-env"
    ],
    "plugins": [
      "@babel/plugin-proposal-class-properties",
      "@babel/plugin-proposal-optional-chaining",
      "@babel/plugin-transform-runtime"
    ]
  },
  "eslintConfig": {
    "extends": [
      "airbnb-base",
      "plugin:prettier/recommended"
    ],
    "rules": {
      "no-console": "warn",
      "no-unused-vars": ["error", { "argsIgnorePattern": "^_" }],
      "import/no-extraneous-dependencies": ["error", { "devDependencies": true }]
    }
  },
  "prettier": {
    "singleQuote": true,
    "trailingComma": "es5",
    "printWidth": 100,
    "tabWidth": 2,
    "semi": true,
    "bracketSpacing": true,
    "arrowParens": "always"
  }
}