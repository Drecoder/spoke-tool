# ============================================================================
# Spoke Tool - Laptop Configuration
# ============================================================================
# 
# Simplified configuration for local laptop development.
# Copy this file to .env and modify as needed.

# ============================================================================
# Core Settings
# ============================================================================

# Log level (debug, info, warn, error)
# Use debug when troubleshooting, info for normal use
LOG_LEVEL=info

# Enable colored output (easier to read)
LOG_COLOR=true

# ============================================================================
# Ollama Settings (MUST CONFIGURE)
# ============================================================================

# Ollama host - usually localhost if running locally
# Default: http://localhost:11434
OLLAMA_HOST=http://localhost:11434

# Models to use (these are the defaults, change if you have different ones)
ENCODER_MODEL=codebert
DECODER_MODEL=deepseek-coder:7b
FAST_MODEL=gemma2:2b

# Model temperature (lower = more consistent, higher = more creative)
# Default: 0.7
MODEL_TEMPERATURE=0.7

# ============================================================================
# Performance Settings (Important for Laptop)
# ============================================================================

# Maximum concurrent operations - lower if your laptop gets hot
# Default: 4, try 2 if you have an older laptop
SQUEEZE_MAX_CONCURRENT=4

# Max CPU percentage before throttling
# Default: 80, lower to 60 if you need to keep laptop cool
SQUEEZE_MAX_CPU=80

# Max memory in MB before throttling
# Default: 4096 (4GB), lower if you have less RAM
SQUEEZE_MAX_MEMORY=4096

# ============================================================================
# Test Generation Settings
# ============================================================================

# Auto-run tests after generation (set to false if you want to review first)
TEST_AUTO_RUN=true

# Coverage threshold - don't be too strict on laptop testing
TEST_COVERAGE_THRESHOLD=70

# Parallel test workers - lower if your laptop struggles
TEST_PARALLEL_WORKERS=2

# ============================================================================
# Paths (Windows-style paths)
# ============================================================================

# Project root (usually auto-detected, set if needed)
# PROJECT_ROOT=C:\WS\spoke-tool

# Output directories
TEST_RESULTS_DIR=test-results
COVERAGE_DIR=coverage
GENERATED_DIR=generated

# ============================================================================
# Optional: API Server (usually not needed on laptop)
# ============================================================================

# Enable API server (set to true only if you need the REST API)
API_ENABLED=false

# ============================================================================
# Debug Settings (enable when troubleshooting)
# ============================================================================

# Enable debug mode for verbose logging
DEBUG=false

# Enable profiling (creates CPU/memory profiles)
PROFILE=false